# NeuralNexus — Environment Configuration
# Copy to .env and fill in values before running.
# Never commit the actual .env file to git.

# ── ATO Chain Detector ────────────────────────
# 300 = demo mode (judges have time to see ATO Chains update)
# 30  = production mode (strict real-time)
ATO_WINDOW_SECONDS=300

# ── Adaptive Retraining ───────────────────────
# 10 = demo mode (triggers quickly for live demonstration)
# 50 = production mode
RETRAIN_MIN_LABELS=10

# ── Redis ─────────────────────────────────────
# 0 = use fakeredis (zero setup, recommended for demo)
# 1 = use real Redis (must have redis-server running)
USE_REAL_REDIS=0
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Demo Mode ─────────────────────────────────
DEMO_MODE=1

# ── Admin API ─────────────────────────────────
# Used for POST /model/retrain — keep secret in production
ADMIN_KEY=nexus-dev

# ── FastAPI ───────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── MLflow ───────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns
